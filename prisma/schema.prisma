generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  extensions = [pgvector]
}

// ========== 管理员 ==========
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  accounts Account[]
  sessions Session[]
}

// ========== 内容 ==========
model Content {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String   @default("")
  category  String   @default("article") // article, project, note, page, link, slogan
  metadata  Json     @default("{}")
  status    String   @default("draft")   // draft, published
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks Chunk[] @relation("ChunkToContent")

  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([category, status])
}

// ========== 向量分块 ==========
model Chunk {
  id           String   @id @default(cuid())
  content      String
  contentHash  String
  embedding    Unsupported("vector")?
  contentId    String
  parent       Content @relation("ChunkToContent", fields: [contentId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([contentId])
  @@index([contentHash])
}

// ========== 站点配置 ==========
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())

  @@index([key])
}

// ========== NextAuth 兼容 ==========
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Admin @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user Admin @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
