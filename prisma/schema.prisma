generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  accounts     Account[]
  sessions     Session[]
}

model Content {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String   @default("")
  category  String   @default("article")
  metadata  Json     @default("{}")
  status    String   @default("draft")
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chunks    Chunk[]  @relation("ChunkToContent")

  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([category, status])
}

model Chunk {
  id          String                 @id @default(cuid())
  content     String
  contentHash String
  embedding   Unsupported("vector")?
  contentId   String
  createdAt   DateTime               @default(now())
  parent      Content                @relation("ChunkToContent", fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([contentHash])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())

  @@index([key])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Admin   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
