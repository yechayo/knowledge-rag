generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  accounts     Account[]
  sessions     Session[]
}

model Content {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String   @default("")
  category  String   @default("article")
  metadata  Json     @default("{}")
  status    String   @default("draft")
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chunks    Chunk[]  @relation("ChunkToContent")
  images    Image[]

  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([category, status])
}

model Image {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  contentId String?
  createdAt DateTime @default(now())
  content   Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model Chunk {
  id             String                 @id @default(cuid())
  content        String
  contentHash    String
  embedding      Unsupported("vector")?
  contentId      String
  createdAt      DateTime               @default(now())
  chunkType      String                 @default("content_body")
  headingAnchor  String?
  headingLevel   Int?
  headingText    String?
  sectionPath    String?
  sourceCategory String?
  sourceSlug     String?
  sourceTags     Json                   @default("[]")
  sourceTitle    String?
  parent         Content                @relation("ChunkToContent", fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([contentHash])
  @@index([chunkType])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())

  @@index([key])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Admin   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UsageLog {
  id             String   @id @default(cuid())
  sessionId      String?  // 对话会话 ID（如果有）
  query          String   // 用户问题
  answerLength   Int      @default(0) // 回答长度
  citations      Int      @default(0) // 引用数量
  latencyMs      Int      @default(0) // 响应延迟（毫秒）
  promptTokens   Int      @default(0) // 输入 token 数
  completionTokens Int    @default(0) // 输出 token 数
  totalTokens   Int      @default(0) // 总 token 数
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

model AgentSession {
  id          String   @id @default(cuid())
  sessionKey  String   @unique
  userId      String
  agentId     String
  status      String   @default("idle")
  messages    Json     @default("[]")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 长对话统计
  tokenUsage   Int      @default(0)    // 累计 token 使用量
  messageCount Int      @default(0)    // 累计消息数
  compactCount Int      @default(0)    // 压缩次数

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([userId, sessionKey])
}

model Task {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  agentType     String    @default("react")
  triggerType   String    @default("manual") // manual | cron
  cronExpr      String?                        // cron 表达式
  scheduleKind  String?                        // cron | every | at
  everyMs       Int?                          // 间隔毫秒（every 用）
  atMs          DateTime?                     // 一次性时间（at 用）
  nextRunAt     DateTime?                     // 下次执行时间
  lastRunAt     DateTime?                     // 上次执行时间
  lastError     String?                       // 上次错误信息
  enabled       Boolean   @default(true)       // 启用/停用
  tools         Json      @default("[]")
  prompt        String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([triggerType, enabled, nextRunAt])
}

model AgentMemory {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  type        String   @default("user")  // user | feedback | project | reference
  name        String
  description String?
  content     String
  isPrivate   Boolean  @default(true)   // true = 仅当前管理员可见
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([userId])
  @@index([isPrivate])
  @@index([updatedAt])
}

// ============ Skill 市场系统 ============

// Skill 市场条目（管理员发布）
model SkillMarket {
  id           String    @id @default(cuid())
  name         String    @unique
  description  String?
  author       String?
  version      String    @default("1.0.0")
  sourceType   String?   // "github" | "local" | "url"
  sourceUrl    String?
  category     String    @default("general")
  tags        Json      @default("[]")
  installCount Int       @default(0)
  status       String    @default("approved") // pending | approved | rejected
  manifest     Json?     // 完整的 manifest 信息
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  installedSkills InstalledSkill[]
  installRequests SkillInstallRequest[]

  @@index([status])
  @@index([category])
  @@index([name])
}

// 用户已安装的 Skill
model InstalledSkill {
  id          String   @id @default(cuid())
  userId      String
  skillName   String
  version     String   @default("1.0.0")
  status      String   @default("pending_approval") // pending_approval | active | disabled
  localPath   String?
  marketId    String?
  market      SkillMarket? @relation(fields: [marketId], references: [id])
  approvedAt  DateTime?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, skillName])
  @@index([userId])
  @@index([status])
}

// Skill 安装申请
model SkillInstallRequest {
  id         String   @id @default(cuid())
  userId     String
  skillName  String
  version    String   @default("1.0.0")
  reason     String?
  status     String   @default("pending") // pending | approved | rejected
  marketId   String?
  market     SkillMarket? @relation(fields: [marketId], references: [id])
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime @default(now())

  @@index([userId, status])
  @@index([status])
}
