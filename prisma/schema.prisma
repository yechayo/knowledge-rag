generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  accounts     Account[]
  sessions     Session[]
}

model Content {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String   @default("")
  category  String   @default("article")
  metadata  Json     @default("{}")
  status    String   @default("draft")
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chunks    Chunk[]  @relation("ChunkToContent")
  images    Image[]

  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([category, status])
}

model Image {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  contentId String?
  createdAt DateTime @default(now())
  content   Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model Chunk {
  id             String                 @id @default(cuid())
  content        String
  contentHash    String
  embedding      Unsupported("vector")?
  contentId      String
  createdAt      DateTime               @default(now())
  chunkType      String                 @default("content_body")
  headingAnchor  String?
  headingLevel   Int?
  headingText    String?
  sectionPath    String?
  sourceCategory String?
  sourceSlug     String?
  sourceTags     Json                   @default("[]")
  sourceTitle    String?
  parent         Content                @relation("ChunkToContent", fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([contentHash])
  @@index([chunkType])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())

  @@index([key])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Admin   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UsageLog {
  id             String   @id @default(cuid())
  sessionId      String?  // 对话会话 ID（如果有）
  query          String   // 用户问题
  answerLength   Int      @default(0) // 回答长度
  citations      Int      @default(0) // 引用数量
  latencyMs      Int      @default(0) // 响应延迟（毫秒）
  promptTokens   Int      @default(0) // 输入 token 数
  completionTokens Int    @default(0) // 输出 token 数
  totalTokens   Int      @default(0) // 总 token 数
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

model AgentSession {
  id          String   @id @default(cuid())
  sessionKey  String   @unique
  userId      String
  agentId     String
  status      String   @default("idle")
  messages    Json     @default("[]")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([userId, sessionKey])
}

model Task {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  agentType   String   @default("react")
  triggerType String   @default("manual")
  cronExpr    String?
  tools       Json     @default("[]")
  prompt      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([triggerType])
  @@index([isActive])
}
