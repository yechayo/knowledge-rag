// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// User model for NextAuth
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  knowledgeBases KnowledgeBase[]
  documents      Document[]
  chunks         Chunk[]
}

// --- 业务模型开始 ---

model KnowledgeBase {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
  chunks    Chunk[]

  @@index([userId])
}

model Document {
  id           String    @id @default(cuid())
  filename     String
  storagePath  String    // 存储路径（Supabase Storage 或 本地）
  mime         String    @default("application/pdf")
  status       String    @default("uploaded") // uploaded, processing, ready, error
  error        String?
  kbId         String
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  indexedAt    DateTime?

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        Chunk[]

  @@index([kbId])
  @@index([userId])
}

model Chunk {
  id          String   @id @default(cuid())
  content     String   @db.Text
  contentHash String?  // 用于去重(可选)
  pageStart   Int
  pageEnd     Int
  
  // Vector 字段：手动指定 vector(256)
  // 虽然 Prisma 目前通过 Unsupported 支持，但我们需要在迁移后手动处理或使用 Raw SQL
  embedding   Unsupported("vector(256)")?

  kbId        String
  docId       String
  userId      String
  createdAt   DateTime @default(now())

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  document      Document      @relation(fields: [docId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kbId])
  @@index([docId])
  @@index([userId])
}

// --- 业务模型结束 ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
