DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
NEXTAUTH_SECRET="random_string"
NEXTAUTH_URL="http://localhost:3000"
BIGMODEL_API_KEY="your_zhipu_api_key"
EMBEDDING_DIMENSIONS=256
TAVILY_API_KEY="your_tavily_api_key"
ADMIN_EMAIL="admin@example.com"
MCP_API_KEY="your_mcp_api_key"

# Agent 专用模型配置（可选，不配置则 Agent 使用 GLM glm-4-flash）
# 配置后可切换为 OpenAI/DeepSeek/OpenRouter 等任意 OpenAI-compatible 模型
# AGENT_MODEL_NAME=gpt-4o
# AGENT_API_KEY=your_agent_api_key
# AGENT_BASE_URL=https://api.openai.com/v1
# AGENT_TEMPERATURE=0.7
# AGENT_MAX_TOKENS=4000

# Aliyun OSS (optional, OSS enabled when these are set)
# You can use either ALIYUN_OSS_* or OSS_* variable names
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_REGION="oss-cn-hangzhou"
# Optional when region is provided
ALIYUN_OSS_ENDPOINT=""
# Optional public domain or bucket URL, e.g. https://your-bucket.oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_PUBLIC_URL=""
# Optional, default true
ALIYUN_OSS_SECURE="true"
